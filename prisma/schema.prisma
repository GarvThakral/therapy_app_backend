generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
}

enum EntryType {
  trigger
  event
  thought
  win
}

enum CommunityReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  name                 String?
  passwordHash         String
  plan                 Plan                  @default(FREE)
  logs                 LogEntry[]
  sessions             TherapySession[]
  homework             HomeworkItem[]
  profile              UserProfile?
  communityPosts       CommunityPost[]
  communityComments    CommunityComment[]
  communityPostLikes   CommunityPostLike[]
  communityCommentLikes CommunityCommentLike[]
  communityReports     CommunityReport[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model LogEntry {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  text        String
  type        EntryType
  intensity   Int
  addedToPrep Boolean   @default(false)
  prepNote    String?
  checkedOff  Boolean   @default(false)
  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, isArchived, createdAt])
}

model UserProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName            String   @default("Alex")
  therapistName          String?
  sessionFrequency       String   @default("weekly")
  sessionDay             String   @default("Thursday")
  sessionTime            String   @default("10:00")
  nextSessionDate        DateTime?
  preSessionReminder     Int      @default(2)
  postSessionReminder    Int      @default(1)
  enablePreReminder      Boolean  @default(true)
  enablePostReminder     Boolean  @default(true)
  enableHomeworkReminder Boolean  @default(true)
  enableWeeklyNudge      Boolean  @default(false)
  theme                  String   @default("dark")
  fontSize               String   @default("standard")
  aiSuggestions          Boolean  @default(false)
  onboarded              Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model TherapySession {
  id           String         @id @default(cuid())
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  number       Int
  date         DateTime
  endDate      DateTime?
  topics       String[]
  whatStoodOut String
  prepItems    String[]
  postMood     Int
  moodWord     String?
  completed    Boolean        @default(true)
  homework     HomeworkItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId, date])
  @@index([userId, endDate, date])
  @@unique([userId, number])
}

model HomeworkItem {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId     String?
  session       TherapySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  text          String
  sessionDate   DateTime
  dueDate       DateTime?
  completed     Boolean        @default(false)
  completedDate DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, completed, sessionDate])
  @@index([sessionId])
}

model CommunityPost {
  id        String              @id @default(cuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  tag       String
  isHidden  Boolean             @default(false)
  hiddenAt  DateTime?
  hiddenReason String?
  comments  CommunityComment[]
  likes     CommunityPostLike[]
  reports   CommunityReport[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([tag, createdAt])
  @@index([isHidden, createdAt])
}

model CommunityComment {
  id        String               @id @default(cuid())
  postId    String
  post      CommunityPost        @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  isHidden  Boolean              @default(false)
  hiddenAt  DateTime?
  hiddenReason String?
  likes     CommunityCommentLike[]
  reports   CommunityReport[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([createdAt])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@index([isHidden, createdAt])
}

model CommunityPostLike {
  userId    String
  postId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@id([userId, postId])
  @@index([postId])
}

model CommunityCommentLike {
  userId    String
  commentId String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@id([userId, commentId])
  @@index([commentId])
}

model CommunityReport {
  id         String                @id @default(cuid())
  reporterId String
  reporter   User                  @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  postId     String?
  post       CommunityPost?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId  String?
  comment    CommunityComment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reason     String
  details    String?
  status     CommunityReportStatus @default(OPEN)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([reporterId, createdAt])
  @@index([postId, createdAt])
  @@index([commentId, createdAt])
  @@index([status, createdAt])
}
